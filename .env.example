# ── AI Keys ──────────────────────────────────────────────────
# Anthropic Claude (bug extraction & sufficiency assessment)
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# OpenAI Whisper API (video transcription)
OPENAI_API_KEY=sk-YOUR-KEY-HERE

# ── Azure DevOps ──────────────────────────────────────────────
ADO_ORG_URL=https://dev.azure.com/CoraSystems
ADO_PAT=YOUR-ADO-PERSONAL-ACCESS-TOKEN
ADO_PROJECT=PPM

# ── Jira (Cloud) ──────────────────────────────────────────────
# Base URL of your Jira instance (no trailing slash)
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Jira account email + API token
# Generate a token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=YOUR-JIRA-API-TOKEN
